# ═══ JECI Options Bot v2 — Environment ═══════════════════════════════════════
# cp .env.example .env → fill in your values

# ── Tastytrade ────────────────────────────────────────────────────────────────
TT_USERNAME=your_tastytrade_username
TT_PASSWORD=your_tastytrade_password
TASTYTRADE_PAPER=true              # false = LIVE money. Validate on paper first.

ACCT_TRADERSURFER=5WX-XXXXX        # Master Swing Desk
ACCT_ROBYHOOD=5WX-XXXXX            # Kids' Sandbox
ACCT_HODL=5WX-XXXXX                # Family HODL (alerts only, never auto-trades)

# ── Execution ─────────────────────────────────────────────────────────────────
AUTO_EXECUTE=false                 # true = no confirmation prompts (after 30d paper)
CONSENSUS_REQUIRED=true            # true = 3/3 agent vote required to route entries
                                   # (if true with missing keys → alert-only mode)

# ── Tri-Agent Consensus Network keys ─────────────────────────────────────────
XAI_API_KEY=                       # Grok  → console.x.ai
ANTHROPIC_API_KEY=                 # Claude → console.anthropic.com
GOOGLE_API_KEY=                    # Gemini → aistudio.google.com/apikey

# Model overrides (optional)
GROK_MODEL=grok-4
CLAUDE_MODEL=claude-sonnet-4-5
GEMINI_MODEL=gemini-2.5-flash
AGENT_TIMEOUT_SEC=25

# ── Master Risk Moat (change only with intention) ─────────────────────────────
SANDBOX_MAX_PREMIUM=150.00         # $ hard ceiling per Robyhood trade
LARGE_ACCT_POSITION_PCT=3.29       # % of TraderSurfer net liq per position
